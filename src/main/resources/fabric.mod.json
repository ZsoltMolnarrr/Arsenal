{
  "schemaVersion": 1,
  "id": "arsenal",
  "version": "${version}",
  "name": "Relics (RPG Series)",
  "description": "Unleash your true potential with powerful trinkets!",
  "authors": [ "Daedelus" ],
  "contact": {},
